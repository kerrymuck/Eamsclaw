# EAMS 环境配置文件
# 复制此文件为 .env 并修改配置

# ==========================================
# 应用配置
# ==========================================
APP_NAME=EAMS
DEBUG=false

# ==========================================
# 数据库配置 (PostgreSQL)
# ==========================================
# 本地开发
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eams

# 生产环境 (示例)
# DATABASE_URL=postgresql://username:password@host:5432/eams

# ==========================================
# Redis配置
# ==========================================
REDIS_URL=redis://localhost:6379/0

# ==========================================
# RabbitMQ配置 (可选)
# ==========================================
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ==========================================
# 安全配置
# ==========================================
# 生产环境必须修改！
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==========================================
# CORS配置
# ==========================================
# 开发环境
ALLOWED_HOSTS=["*"]

# 生产环境 (示例)
# ALLOWED_HOSTS=["https://your-domain.com", "https://app.your-domain.com"]

# ==========================================
# AI配置 (OpenAI)
# ==========================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# 备用AI配置 (可选)
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_ORG_ID=your-org-id

# ==========================================
# 平台API配置 (可选)
# ==========================================
# 淘宝开放平台
TAOBAO_APP_KEY=your-taobao-app-key
TAOBAO_APP_SECRET=your-taobao-app-secret

# 京东开放平台
JD_APP_KEY=your-jd-app-key
JD_APP_SECRET=your-jd-app-secret

# 拼多多开放平台
PDD_CLIENT_ID=your-pdd-client-id
PDD_CLIENT_SECRET=your-pdd-client-secret

# ==========================================
# 文件上传配置
# ==========================================
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=uploads

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=logs/eams.log
